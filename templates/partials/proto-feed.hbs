<!-- Taboola Feed Section -->
<div style="max-width: 760px; margin: 0 auto; padding: 0 16px 40px;">

  <!-- Feed Header -->
  <div style="border-top: 3px solid var(--brand-primary); padding-top: 16px; margin-bottom: 24px;">
    <div class="section-label" style="border-bottom: none; margin-bottom: 0;">
      <span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:var(--brand-primary);margin-right:8px;vertical-align:middle;"></span>
      Sponsored Stories
    </div>
  </div>

  <!-- Large Sponsored Cards (2-up) -->
  <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 32px;">
    {{#each feedContent.sponsoredLarge}}
      {{> components-feed-card this size="large"}}
    {{/each}}
  </div>

  <!-- Dense Sponsored Cards (3-up) -->
  <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 16px; margin-bottom: 32px;">
    {{#each feedContent.sponsoredDense}}
      {{> components-feed-card this size="small"}}
    {{/each}}
  </div>

  <!-- Native Section -->
  <div style="margin-bottom: 32px;">
    <div class="section-label">
      <span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:var(--brand-primary);margin-right:8px;vertical-align:middle;"></span>
      More From {{../brandKit.brand.name}}
    </div>
    <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 16px;">
      {{#each feedContent.nativeSection}}
        {{> components-feed-card this size="small"}}
      {{/each}}
    </div>
  </div>

  <!-- Mixed Sponsored (2-up) -->
  <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 32px;">
    {{#each feedContent.sponsoredMixed}}
      {{> components-feed-card this size="large"}}
    {{/each}}
  </div>

  <!-- Trending Native (4-up) -->
  <div style="margin-bottom: 32px;">
    <div class="section-label">
      <span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:var(--brand-primary);margin-right:8px;vertical-align:middle;"></span>
      Trending on {{../brandKit.brand.name}}
    </div>
    <div style="display: grid; grid-template-columns: 1fr 1fr 1fr 1fr; gap: 14px;">
      {{#each feedContent.trendingNative}}
        {{> components-feed-card this size="tiny"}}
      {{/each}}
    </div>
  </div>

  <!-- Final Sponsored -->
  <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px;">
    {{#each feedContent.sponsoredFinal}}
      {{> components-feed-card this size="large"}}
    {{/each}}
  </div>

  <!-- Taboola Attribution -->
  <div style="text-align: center; padding: 16px 0; font-size: 11px; color: var(--brand-text-tertiary);">
    by <strong>Taboola</strong> | Sponsored Links
  </div>
</div>
