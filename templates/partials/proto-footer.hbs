<!-- Publisher Footer -->
<footer style="background: var(--brand-bg-dark); color: rgba(255,255,255,0.7); padding: 48px 16px 24px;">
  <div style="max-width: 1200px; margin: 0 auto;">
    <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 32px; margin-bottom: 32px;">
      {{#each navigation.footerLinks}}
        <div>
          <h4 style="color: #fff; font-size: 14px; font-weight: 700; margin: 0 0 12px; text-transform: uppercase; letter-spacing: 0.05em;">
            {{this.group}}
          </h4>
          {{#each this.links}}
            <a href="#" style="display: block; color: rgba(255,255,255,0.6); font-size: 13px; padding: 3px 0; text-decoration: none;">{{this.text}}</a>
          {{/each}}
        </div>
      {{/each}}
      {{#unless navigation.footerLinks}}
        <div>
          <h4 style="color: #fff; font-size: 14px; font-weight: 700; margin: 0 0 12px;">About</h4>
          <a href="#" style="display: block; color: rgba(255,255,255,0.6); font-size: 13px; padding: 3px 0;">About Us</a>
          <a href="#" style="display: block; color: rgba(255,255,255,0.6); font-size: 13px; padding: 3px 0;">Contact</a>
          <a href="#" style="display: block; color: rgba(255,255,255,0.6); font-size: 13px; padding: 3px 0;">Careers</a>
        </div>
        <div>
          <h4 style="color: #fff; font-size: 14px; font-weight: 700; margin: 0 0 12px;">Legal</h4>
          <a href="#" style="display: block; color: rgba(255,255,255,0.6); font-size: 13px; padding: 3px 0;">Privacy Policy</a>
          <a href="#" style="display: block; color: rgba(255,255,255,0.6); font-size: 13px; padding: 3px 0;">Terms of Service</a>
        </div>
      {{/unless}}
    </div>

    {{#if navigation.socialLinks}}
      <div style="display: flex; gap: 16px; margin-bottom: 24px;">
        {{#each navigation.socialLinks}}
          <a href="#" style="color: rgba(255,255,255,0.5); font-size: 13px; text-decoration: none;">{{this.platform}}</a>
        {{/each}}
      </div>
    {{/if}}

    <div style="border-top: 1px solid rgba(255,255,255,0.1); padding-top: 16px; font-size: 12px; opacity: 0.5;">
      &copy; 2025 {{brandKit.brand.name}}. All rights reserved. | Brand Kit Prototype generated by Taboola Brand Kit Generator
    </div>
  </div>
</footer>
