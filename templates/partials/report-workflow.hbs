<!-- Workflow Comparison -->
<div style="margin-bottom: 32px;">
  <div class="section-title"><h2>Workflow Comparison</h2></div>
  <div class="grid-2">
    <!-- Manual Workflow -->
    <div class="card" style="border-top: 3px solid #ef4444;">
      <h3 style="font-size: 16px; margin-bottom: 16px;">
        <span style="color: #ef4444;">Manual Process</span>
        <span style="font-size: 12px; color: var(--text-muted); margin-left: 8px;">~2-4 hours per publisher</span>
      </h3>
      <ol style="list-style: none; counter-reset: step;">
        {{#each analysis.workflow.manual}}
          <li style="position: relative; padding: 8px 0 8px 36px; border-left: 2px solid var(--border); margin-left: 12px; font-size: 13px; color: var(--text-muted);">
            <span style="position: absolute; left: -9px; top: 8px; width: 16px; height: 16px; border-radius: 50%; background: var(--bg-card); border: 2px solid #ef4444; font-size: 9px; display: flex; align-items: center; justify-content: center; color: #ef4444;">{{add @index 1}}</span>
            {{this}}
          </li>
        {{/each}}
      </ol>
    </div>
    <!-- Crawler Workflow -->
    <div class="card" style="border-top: 3px solid var(--success);">
      <h3 style="font-size: 16px; margin-bottom: 16px;">
        <span style="color: var(--success);">Automated Crawler</span>
        <span style="font-size: 12px; color: var(--text-muted); margin-left: 8px;">~30 seconds</span>
      </h3>
      <ol style="list-style: none;">
        {{#each analysis.workflow.crawler}}
          <li style="position: relative; padding: 8px 0 8px 36px; border-left: 2px solid var(--border); margin-left: 12px; font-size: 13px; color: var(--text-muted);">
            <span style="position: absolute; left: -9px; top: 8px; width: 16px; height: 16px; border-radius: 50%; background: var(--bg-card); border: 2px solid var(--success); font-size: 9px; display: flex; align-items: center; justify-content: center; color: var(--success);">{{add @index 1}}</span>
            {{this}}
          </li>
        {{/each}}
      </ol>
    </div>
  </div>
</div>
