<!-- Status Tag Component -->
{{#if (eq status 'drift')}}
  <span style="display:inline-block;padding:2px 8px;border-radius:9999px;font-size:11px;font-weight:600;background:#fef3c7;color:#92400e">Drift</span>
{{else if (eq status 'missing')}}
  <span style="display:inline-block;padding:2px 8px;border-radius:9999px;font-size:11px;font-weight:600;background:#dbeafe;color:#1e40af">New</span>
{{else}}
  <span style="display:inline-block;padding:2px 8px;border-radius:9999px;font-size:11px;font-weight:600;background:#d1fae5;color:#065f46">Match</span>
{{/if}}
