<!-- Stat Card Component -->
<div class="card" style="text-align: center; padding: 20px 16px;">
  <div style="font-size: 36px; font-weight: 700; color: {{color}}; line-height: 1;">{{value}}</div>
  <div style="font-size: 12px; color: var(--text-muted); margin-top: 6px; text-transform: uppercase; letter-spacing: 0.04em;">{{title}}</div>
</div>
