<!DOCTYPE html>
<html lang="{{brandKit.brand_voice.language}}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{brandKit.brand.name}} — Feed Prototype</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="{{googleFontsUrl}}" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    :root {
      --brand-primary: {{default brandKit.colors.primary.hex '#1a73e8'}};
      --brand-text: {{default brandKit.colors.text.primary.hex '#1a1a1a'}};
      --brand-text-secondary: {{default brandKit.colors.text.secondary.hex '#555555'}};
      --brand-text-tertiary: {{default brandKit.colors.text.tertiary.hex '#888888'}};
      --brand-bg: {{default brandKit.colors.backgrounds.base.hex '#ffffff'}};
      --brand-bg-section: {{default brandKit.colors.backgrounds.section.hex '#f5f5f5'}};
      --brand-bg-dark: {{default brandKit.colors.backgrounds.dark.hex '#1a1a1a'}};
      --font-headline: '{{resolveFont brandKit.fonts.primary.family}}', sans-serif;
      --font-body: '{{resolveFont brandKit.fonts.secondary.family}}', sans-serif;
    }
    body {
      font-family: var(--font-body);
      color: var(--brand-text);
      background: var(--brand-bg);
      margin: 0;
    }
    .brand-accent { color: var(--brand-primary); }
    .brand-accent-bg { background: var(--brand-primary); }
    .headline-font { font-family: var(--font-headline); }
    .body-font { font-family: var(--font-body); }
    a { color: var(--brand-primary); text-decoration: none; }
    a:hover { text-decoration: underline; }

    /* Feed card styles */
    .feed-card { transition: box-shadow 0.2s; }
    .feed-card:hover { box-shadow: 0 2px 12px rgba(0,0,0,0.1); }
    .feed-card img { width: 100%; aspect-ratio: 4/3; object-fit: cover; }
    .feed-card-headline {
      font-family: var(--font-headline);
      font-weight: 700;
      color: var(--brand-text);
      line-height: 1.3;
    }
    .feed-card-headline:hover { text-decoration: underline; }
    .feed-card-source {
      font-size: 12px;
      color: var(--brand-text-tertiary);
      text-transform: uppercase;
      letter-spacing: 0.02em;
    }
    .feed-card-cta {
      font-size: 12px;
      color: var(--brand-primary);
      font-weight: 600;
    }
    .section-label {
      font-family: var(--font-headline);
      font-size: 13px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--brand-text-secondary);
      padding-bottom: 8px;
      margin-bottom: 16px;
      border-bottom: 3px solid var(--brand-primary);
    }
    .badge-sponsored {
      font-size: 10px;
      padding: 2px 6px;
      border-radius: 3px;
      background: var(--brand-bg-section);
      color: var(--brand-text-tertiary);
      text-transform: uppercase;
      letter-spacing: 0.04em;
      font-weight: 600;
    }
  </style>
</head>
<body>
  {{> proto-nav}}
  {{> proto-hero}}
  {{> proto-article}}
  {{> proto-feed}}
  {{> proto-footer}}
</body>
</html>
